{
  "name": "lazule-fragrances-catalog",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/generateSeoAssets.js dist",
    "preview": "vite preview",
    "scrape:supplier": "node scripts/scrapeSupplier.js",
    "import:supplier-json": "node scripts/importSupplierJson.js",
    "validate:products": "node scripts/validateProducts.js",
    "validate:recommendations": "node scripts/validateRecommendations.js",
    "test:utils": "node --test tests/*.test.js",
    "prebuild": "node scripts/generateSeoAssets.js public",
    "enrich:referencePerfumes": "node scripts/enrichReferencePerfumes.js",
    "validate:referencePerfumes": "node scripts/validateReferencePerfumes.js",
    "ingest:knowledge": "node scripts/ingestion/ingestFragrances.js",
    "normalize:knowledge": "node scripts/ingestion/normalizeFragranceData.js",
    "enrich:knowledge": "node scripts/ingestion/enrichFragranceSemanticData.js",
    "validate:knowledge": "node scripts/ingestion/validateKnowledgeEntries.js",
    "build:knowledge-graph": "node scripts/ingestion/buildKnowledgeGraphArtifacts.js",
    "extract:facts": "node scripts/ingestion/extractFragranceFacts.js",
    "generate:fragrance-seeds": "node scripts/ingestion/generateFragranceSeeds.js",
    "discover:fragrances": "node scripts/ingestion/discoverFragranceUrls.js"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "vite": "latest",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.17",
    "postcss": "^8.4.49",
    "autoprefixer": "^10.4.20",
    "playwright": "^1.52.0"
  }
}
